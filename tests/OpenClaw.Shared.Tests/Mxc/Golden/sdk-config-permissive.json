{
  "version": "0.7.0-alpha",
  "containerId": "golden-permissive",
  "lifecycle": {
    "destroyOnExit": true,
    "preservePolicy": false
  },
  "process": {},
  "filesystem": {
    "readwritePaths": [
      "C:\\Golden\\Documents",
      "C:\\Golden\\Downloads",
      "C:\\Golden\\Desktop",
      "C:\\Golden\\Scratch"
    ],
    "readonlyPaths": []
  },
  "ui": {
    "disable": true,
    "clipboard": "all",
    "injection": false
  },
  "network": {
    "defaultPolicy": "allow",
    "enforcementMode": "capabilities"
  },
  "processContainer": {
    "leastPrivilege": false,
    "capabilities": [
      "internetClient"
    ],
    "ui": {
      "isolation": "container",
      "desktopSystemControl": false,
      "systemSettings": "none",
      "ime": false
    }
  }
}
